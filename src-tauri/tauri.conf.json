{
  "productName": "ContextCLI",
  "version": "0.1.0",
  "identifier": "com.contextcli.app",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeBuildCommand": "cd ../ui && pnpm build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "ContextCLI",
        "width": 900,
        "height": 650,
        "center": true,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ]
  }
}
