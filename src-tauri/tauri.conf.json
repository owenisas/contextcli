{
  "productName": "ContextCLI",
  "version": "0.2.2",
  "identifier": "com.contextcli.app",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeBuildCommand": "cd ../ui && pnpm build",
    "beforeBundleCommand": "bash ../scripts/prepare-sidecar.sh"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "ContextCLI",
        "width": 900,
        "height": 650,
        "center": true,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/contextcli"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "./Entitlements.plist"
    }
  }
}
